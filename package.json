{
  "name": "writedown",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "npm run dev -w apps/api",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w apps/api && npm run build -w apps/web"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
